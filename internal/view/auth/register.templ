package authview

import (
	"github.com/impactscope-organization/wobsongo/components/alert"
	"github.com/impactscope-organization/wobsongo/components/button"
	"github.com/impactscope-organization/wobsongo/components/card"
	"github.com/impactscope-organization/wobsongo/components/form"
	"github.com/impactscope-organization/wobsongo/components/input"
	"github.com/impactscope-organization/wobsongo/components/label"
	"github.com/impactscope-organization/wobsongo/internal/view/layout"
)

templ Register(csrfToken, errMsg string) {
	@layout.Public("Create Account") {
		@card.Card(card.Props{Class: "w-[380px]"}) {
			@card.Content(card.ContentProps{Class: "flex flex-col gap-4 p-8"}) {
				<div class="flex items-center gap-2 justify-center">
					<span class="font-semibold text-2xl tracking-tight">wobsongo</span>
				</div>
				<p class="text-center text-sm text-muted-foreground -mt-2">Create your account</p>
				if errMsg != "" {
					@alert.Alert(alert.Props{Variant: alert.VariantDestructive}) {
						@alert.Description() {
							{ errMsg }
						}
					}
				}
				<form method="POST" action="/register" class="flex flex-col gap-4">
					<input type="hidden" name="_csrf" value={ csrfToken }/>
					@form.Item() {
						@label.Label(label.Props{For: "name"}) {
							Name
						}
						@input.Input(input.Props{
							Name:        "name",
							Required:    true,
							Placeholder: "Your name",
						})
					}
					@form.Item() {
						@label.Label(label.Props{For: "email"}) {
							Email
						}
						@input.Input(input.Props{
							Name:        "email",
							Type:        input.TypeEmail,
							Required:    true,
							Placeholder: "you@example.com",
						})
					}
					@form.Item() {
						@label.Label(label.Props{For: "password"}) {
							Password
						}
						@input.Input(input.Props{
							Name:     "password",
							Type:     input.TypePassword,
							Required: true,
						})
						@input.Script()
						<p class="text-xs text-muted-foreground">
							At least 8 characters. Use a mix of letters, numbers, or symbols.
						</p>
					}
					@button.Button(button.Props{Type: button.TypeSubmit, FullWidth: true}) {
						Create account
					}
				</form>
				<p class="text-center text-xs text-muted-foreground">
					Already have an account?{ " " }
					<a href="/login" class="underline hover:text-foreground">Sign in</a>
				</p>
			}
		}
	}
}
