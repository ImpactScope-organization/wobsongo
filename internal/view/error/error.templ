package errview

import (
	"strconv"

	"github.com/impactscope-organization/wobsongo/internal/view/layout"
)

templ Error(code int, message string) {
	@layout.Public(errorTitle(code)) {
		<div class="flex flex-col items-center gap-4 text-center">
			<p class="text-8xl font-bold text-muted-foreground/20">{ strconv.Itoa(code) }</p>
			<h2 class="text-xl font-semibold">{ errorTitle(code) }</h2>
			<p class="text-sm text-muted-foreground max-w-sm">{ message }</p>
			<a
				href="/"
				class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4 py-2"
			>
				Go Home
			</a>
		</div>
	}
}

func errorTitle(code int) string {
	switch code {
	case 400:
		return "Bad Request"
	case 403:
		return "Forbidden"
	case 404:
		return "Not Found"
	case 409:
		return "Conflict"
	case 500:
		return "Internal Server Error"
	default:
		return "Something went wrong"
	}
}
