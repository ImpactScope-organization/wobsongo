# Application
APP_ENV=development
APP_LOG_LEVEL=1
APP_PORT=8000

# Database
APP_DB_URI=postgres://wobsongocore:LocalDev123@localhost:45432/wobsongocore_db?sslmode=disable

# Authentication
APP_JWT_SECRET=change-me-in-production
APP_JWT_EXPIRY_HOURS=24

# Hosts & CORS
API_HOST=localhost:8000
FRONTEND_HOST=localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Storage
STORAGE_PROVIDER=local

# Email (use 'mailhog' for local dev, 'smtp' for production)
EMAIL_PROVIDER_TRANSACTIONAL=mailhog
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Wobsongo
EMAIL_FROM_ADDRESS=noreply@wobsongo.example.com

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# S3_ENDPOINT=localhost:9090
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET=minioadmin
# S3_BUCKET_NAME=wobsongo
# S3_USE_SSL=false

# VLM (image captioning) — a generic OpenAI-compatible vision chat-completions
# endpoint (works against self-hosted vLLM/Ollama or a hosted open-weight-model
# provider using that shape). Required for the server to start.
# VLM_BASE_URL=http://localhost:8080
# VLM_MODEL=qwen2-vl-7b-instruct
# VLM_API_KEY=

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=

# Error tracking (optional)
# SENTRY_DSN=
