# Application
APP_ENV=development
APP_LOG_LEVEL=1
APP_PORT=8000

# Database
APP_DB_URI=postgres://wobsongocore:LocalDev123@localhost:45432/wobsongocore_db?sslmode=disable

# Authentication
APP_JWT_SECRET=change-me-in-production
APP_JWT_EXPIRY_HOURS=24

# Hosts & CORS
API_HOST=localhost:8000
FRONTEND_HOST=localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Storage
STORAGE_PROVIDER=local

# Email (use 'mailhog' for local dev, 'smtp' for production)
EMAIL_PROVIDER_TRANSACTIONAL=mailhog
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Wobsongo
EMAIL_FROM_ADDRESS=noreply@wobsongo.example.com

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# S3_ENDPOINT=localhost:9090
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET=minioadmin
# S3_BUCKET_NAME=wobsongo
# S3_USE_SSL=false

# VLM (image captioning) — a generic OpenAI-compatible vision chat-completions
# endpoint (works against self-hosted vLLM/Ollama or a hosted open-weight-model
# provider using that shape). Required for the server to start.
# VLM_BASE_URL=http://localhost:8080
# VLM_MODEL=qwen2-vl-7b-instruct
# VLM_API_KEY=

# Embedding (chunk + atomic knowledge embeddings) — a generic OpenAI-compatible
# /v1/embeddings endpoint (works against self-hosted vLLM/text-embeddings-inference
# or a hosted provider using that shape). Required for the server to start.
# Must produce vectors matching the embedding columns' dimension (currently 1024,
# sized for BGE-M3 — MIT-licensed. If you use a different model, both
# document_chunks.embedding and atomic_knowledge.embedding need a migration to
# match its output dimension; see sql/migrations/000007_change_embedding_dimension_to_1024.up.sql
# for the pattern, and clear existing embeddings so they get recomputed).
# EMBEDDING_BASE_URL=http://localhost:8081
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_API_KEY=
# EMBEDDING_PROVIDER selects the wire shape: "openai" (default) for the
# generic /v1/embeddings shape above, or "modal-bge" for a bespoke
# Modal-hosted sentence-transformers deployment (a single POST to
# EMBEDDING_BASE_URL itself with {"texts": [...]}, not /v1/embeddings —
# see external/modal_bge_client.go).
# EMBEDDING_PROVIDER=openai

# Extraction (atomic knowledge) — a generic OpenAI-compatible text
# chat-completions endpoint (works against self-hosted vLLM/Ollama or a
# hosted provider using that shape). Decoupled from VLM_*: this is text-only
# reasoning, not vision. Required for the server to start.
# EXTRACTION_BASE_URL=http://localhost:8082
# EXTRACTION_MODEL=llama-3.1-70b-instruct
# EXTRACTION_API_KEY=
# How many chunks ExtractKnowledgeWorker extracts concurrently. Optional,
# defaults to 5 if unset/invalid — tune based on your provider's actual
# rate-limit tolerance.
# EXTRACTION_CONCURRENCY=5

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=

# Error tracking (optional)
# SENTRY_DSN=
